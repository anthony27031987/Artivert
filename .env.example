# ============================================
# ARTIVERT - Configuration d'environnement
# ============================================

# DATABASE
DATABASE_URL=postgresql://artivert_user:artivert_password_secure_123@localhost:5432/artivert_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=artivert_db
DB_USER=artivert_user
DB_PASSWORD=artivert_password_secure_123

# NODE
NODE_ENV=development
PORT=5000

# JWT
JWT_SECRET=change_me_in_production_with_a_strong_secret_key_at_least_32_chars
JWT_EXPIRE=7d

# FRONTEND
FRONTEND_URL=http://localhost:3000
REACT_APP_API_URL=http://localhost:5000

# GOOGLE MAPS
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# EMAIL (optionnel pour notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@artivert.fr

# APPLICATION
APP_NAME=Artivert
APP_TIMEZONE=Europe/Paris

# RGPD
GEOLOCATION_RETENTION_DAYS=90
AUDIT_LOGS_RETENTION_DAYS=365

# DEBUG
DEBUG=false
LOG_LEVEL=info
